{
  "name": "@xavifabregat/spotify-mcp",
  "version": "0.1.1",
  "description": "MCP server to control Spotify conversationally from Claude, Cursor, and other AI clients",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "spotify",
    "claude",
    "cursor",
    "ai"
  ],
  "author": "Xavi Fabregat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XavierFabregat/spotify-mcp.git"
  },
  "homepage": "https://github.com/XavierFabregat/spotify-mcp#readme",
  "bugs": "https://github.com/XavierFabregat/spotify-mcp/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "spotify-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "npm run build && vitest run",
    "test:live": "npm run build && node scripts/live-check.mjs",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "auth": "node dist/index.js auth",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "open": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
